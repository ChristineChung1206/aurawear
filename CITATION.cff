date-released: "2026-06-30"
license: AGPL-3.0-or-later
repository-code: "https://github.com/ChristineChung1206/aurawear"
keywords:
  - fashion recommendation
  - personal color analysis
  - human-in-the-loop
  - CLIP
  - Gradio
  - LLM
  - reranking
  - seasonal color theory
