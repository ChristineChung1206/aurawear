# AuraWear Analysis — environment configuration
# Copy this file to .env and fill in your values.
# The app runs without OPENAI_API_KEY (LLM features will be disabled).

OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini

# Catalog path for demo mode.
# Set to data/sample_catalog.csv to run the synthetic demo without DeepFashion data.
# Set to aurawear_analysis/data/items_deepfashion.json for the full private dataset.
CATALOG_PATH=data/sample_catalog.csv

# Directory containing product images.
# For the synthetic demo this points to the bundled placeholder directory.
IMAGES_DIR=assets/synthetic_demo_images

# Optional: path to face parsing ONNX model (CelebAMask-HQ derived, not redistributable).
# Leave empty to run without face parsing (graceful fallback to heuristic ROI masks).
FACE_MODEL_PATH=
